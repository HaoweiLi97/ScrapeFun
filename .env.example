# ScrapeTab Environment Configuration Template
# Copy this file to .env and update the values

# Server Configuration
NODE_ENV=production
PORT=4000

# FlareSolverr Configuration (for bypassing Cloudflare)
FLARESOLVERR_URL=http://flaresolverr:8191/v1

# Database Configuration (Optional - defaults to SQLite)
# DATABASE_URL=file:./prisma/dev.db

# R18Dev Database (Optional - for R18Dev scraper)
# R18DEV_DB_URL=postgresql://postgres:password@postgres:5432/r18db

# TMDB API Configuration (Optional - for TMDB scraper)
# TMDB_API_KEY=your_tmdb_api_key_here

# Translation Service (Optional)
# TRANSLATION_SERVICE=google
# TRANSLATION_API_KEY=your_translation_api_key

# WebDAV Configuration (Optional)
# WEBDAV_URL=http://your-webdav-server
# WEBDAV_USERNAME=your_username
# WEBDAV_PASSWORD=your_password

# Local subtitle persistence (Optional)
# Defaults to /app/data/local-subtitles inside Docker.
# Set this only if you want subtitles stored in a custom mounted path.
# LOCAL_SUBTITLE_DIR=/app/data/local-subtitles

# Logging
# LOG_LEVEL=info

# Docker updater integration (optional)
# Default release channel used when the database setting is still empty.
# UPDATE_DEFAULT_CHANNEL=stable
# Docker Hub repository used by the in-app update checker.
# UPDATE_DOCKERHUB_REPO=haoweil/scrapefun
# Built-in sidecar updater works without extra credentials by default.
# Override only if you disable the built-in sidecar updater.
# UPDATE_WEBHOOK_URL=http://127.0.0.1:4182/update
# Fallback direct command mode if you do not use webhook mode.
# UPDATE_COMMAND=/opt/scrapetab/update.sh

# Security (Optional)
# JWT_SECRET=your_secret_key_here
# CORS_ORIGIN=http://localhost:3000

# Premium Feature Licensing (Remote Service)
# Official license server URL, license mode, signature policy and public key
# are built into the server distribution and are not expected from DockerHub users.
# Public DockerHub deployments should not configure any runtime license credentials up front.
# Users activate Pro later inside Scrapefun by entering a license key.
# Optional internal-only compatibility path: installation token exchange.
# LICENSE_INSTALL_TOKEN=stinst_xxx
# Optional file-based equivalent for Docker secrets.
# LICENSE_INSTALL_TOKEN_FILE=/run/secrets/scrapetab_install_token
# Legacy/internal only: pre-issued runtime credentials.
# LICENSE_SERVER_API_KEY=stlic_runtime_key_for_this_instance
# LICENSE_INSTANCE_ID=my-customer-instance-001
# Deprecated for customer deployments: bootstrap admin credentials are ignored by
# the default DockerHub self-serve activation flow and should not be shipped.
# LICENSE_BOOTSTRAP_ADMIN_KEY=stadm_bootstrap_admin_key
# LICENSE_BOOTSTRAP_NOTES=auto_bootstrap
# LICENSE_ALLOW_PRODUCTION_BOOTSTRAP=false
# Preferred Docker host identity source for machine-strong license binding.
# Mount host machine-id into the container and point this env to the mounted path.
# Host machine-id path is built into the official server distribution.
# Fallback only when host machine-id mount is unavailable.
# LICENSE_HOST_FINGERPRINT=manual-host-identity
# Renew the signed installation lease before it gets too close to expiry (ms).
# LICENSE_INSTALLATION_LEASE_RENEW_WINDOW_MS=3600000
# Acceptable clock skew for signature timestamp verification (ms)
# LICENSE_SIGNATURE_MAX_SKEW_MS=300000
# HTTP timeout when calling remote auth server (ms)
# LICENSE_SERVER_TIMEOUT_MS=8000
# Local short-term authorization grace window when remote auth is temporarily unavailable (ms)
# LOCAL_LICENSE_GRACE_MS=86400000
# Local fallback window for using cached remote session tokens (ms)
# LOCAL_LICENSE_TOKEN_TTL_MS=86400000
# Optional cache TTL (ms) for license status checks
# PREMIUM_MOCK_JELLYFIN_LICENSE_CACHE_TTL_MS=30000

# Performance
# MAX_CONCURRENT_SCRAPES=5
# REQUEST_TIMEOUT=30000
